# ============================================================
# Daily English - 环境变量模板
# ============================================================
# 使用前请复制为 .env 并填入真实值：
#   cp .env.example .env
# 然后编辑 .env 填入你的密钥。

# 微信公众号 API 密钥（必填）
# 从 https://mp.weixin.qq.com  → 开发 → 基本配置 获取
WECHAT_APP_ID=your_wx_app_id_here
WECHAT_APP_SECRET=your_wx_app_secret_here

# DeepSeek API 密钥（必填，内容生成用）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here
